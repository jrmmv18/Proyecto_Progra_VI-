@model List<GaleriaArte.Web.Models.Artista>

@{
    ViewData["Title"] = "Artistas";
}

<div class="page-header page-header-actions">

    <div>
        <h1>Artistas</h1>
        <p>Administración de los artistas registrados en la galería.</p>
    </div>

    <a asp-controller="Artistas"
       asp-action="Create"
       class="btn-primary">
        + Nuevo artista
    </a>

</div>

@if (TempData["Mensaje"] != null)
{
    <div class="message">
        @TempData["Mensaje"]
    </div>
}

@if (Model == null || Model.Count == 0)
{
    <div class="table-card">

        <div class="empty">
            No hay artistas registrados.
        </div>

    </div>
}
else
{
    <div class="table-card">

        <div class="table-responsive">

            <table class="data-table artistas-table">

                <thead>

                    <tr>
                        <th>Artista</th>
                        <th>País</th>
                        <th>Fecha nacimiento</th>
                        <th>Teléfono</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>

                </thead>

                <tbody>

                    @foreach (var artista in Model)
                    {
                        <tr>

                            <td>

                                <div class="artist-name">
                                    @artista.Nombre @artista.Apellido
                                </div>

                                <div class="artist-email">
                                    @(string.IsNullOrWhiteSpace(artista.Correo)
                                        ? "Sin correo registrado"
                                        : artista.Correo)
                                </div>

                            </td>

                            <td>
                                @artista.Pais
                            </td>

                            <td>
                                @(artista.FechaNacimiento?.ToString("dd/MM/yyyy")
                                    ?? "No registrada")
                            </td>

                            <td>
                                @(string.IsNullOrWhiteSpace(artista.Telefono)
                                    ? "No registrado"
                                    : artista.Telefono)
                            </td>

                            <td>

                                @if (artista.Estado)
                                {
                                    <span class="badge status-active">
                                        Activo
                                    </span>
                                }
                                else
                                {
                                    <span class="badge status-inactive">
                                        Inactivo
                                    </span>
                                }

                            </td>

                            <td>

                                <div class="table-actions">

                                    <a asp-controller="Artistas"
                                       asp-action="Edit"
                                       asp-route-id="@artista.IdArtista"
                                       class="btn-edit">
                                        Editar
                                    </a>

                                    <form asp-controller="Artistas"
                                          asp-action="CambiarEstado"
                                          asp-route-id="@artista.IdArtista"
                                          method="post">

                                        @Html.AntiForgeryToken()

                                        <button type="submit"
                                                class="btn-state">

                                            @(artista.Estado
                                                ? "Desactivar"
                                                : "Activar")

                                        </button>

                                    </form>

                                </div>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>
}