@model GaleriaArte.Web.Models.Artista

@{
    ViewData["Title"] = "Nuevo artista";
}

<div class="page-header">
    <h1>Nuevo artista</h1>
    <p>Registra la información del artista en el sistema.</p>
</div>

<div class="form-card">

    <form asp-action="Create" method="post">

        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly"
             class="validation-summary">
        </div>

        <div class="form-grid">

            <div class="form-group">
                <label asp-for="Nombre"></label>

                <input asp-for="Nombre"
                       class="form-control"
                       placeholder="Ingrese el nombre" />

                <span asp-validation-for="Nombre"
                      class="field-validation"></span>
            </div>

            <div class="form-group">
                <label asp-for="Apellido"></label>

                <input asp-for="Apellido"
                       class="form-control"
                       placeholder="Ingrese el apellido" />

                <span asp-validation-for="Apellido"
                      class="field-validation"></span>
            </div>

            <div class="form-group">
                <label asp-for="Pais"></label>

                <input asp-for="Pais"
                       class="form-control"
                       placeholder="Ingrese el país" />

                <span asp-validation-for="Pais"
                      class="field-validation"></span>
            </div>

            <div class="form-group">
                <label asp-for="FechaNacimiento"></label>

                <input asp-for="FechaNacimiento"
                       type="date"
                       class="form-control" />

                <span asp-validation-for="FechaNacimiento"
                      class="field-validation"></span>
            </div>

            <div class="form-group">
                <label asp-for="Correo"></label>

                <input asp-for="Correo"
                       class="form-control"
                       placeholder="correo@ejemplo.com" />

                <span asp-validation-for="Correo"
                      class="field-validation"></span>
            </div>

            <div class="form-group">
                <label asp-for="Telefono"></label>

                <input asp-for="Telefono"
                       class="form-control"
                       placeholder="Ingrese el teléfono" />

                <span asp-validation-for="Telefono"
                      class="field-validation"></span>
            </div>

            <div class="form-group"
                 style="grid-column:1 / -1;">

                <label asp-for="Biografia"></label>

                <textarea asp-for="Biografia"
                          class="form-control"
                          rows="6"
                          placeholder="Ingrese una breve biografía del artista"></textarea>

                <span asp-validation-for="Biografia"
                      class="field-validation"></span>

            </div>

        </div>

        <div class="form-actions">

            <a asp-action="Index"
               class="btn-secondary">
                Cancelar
            </a>

            <button type="submit"
                    class="btn-primary">
                Guardar artista
            </button>

        </div>

    </form>

</div>

@section Scripts {

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}