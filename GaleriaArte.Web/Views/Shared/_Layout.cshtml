<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="utf-8" />
    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - Galería de Arte</title>

    <!-- Estilo general existente -->
    <link rel="stylesheet"
          href="~/css/site.css"
          asp-append-version="true" />

    <!-- NUEVA ASOCIACIÓN: Tu archivo separado de estilos para el menú -->
    <link rel="stylesheet" 
          href="~/css/sidebar-hover.css" 
          asp-append-version="true" />
</head>

<body>

@{
    var controlador =
        ViewContext.RouteData.Values["Controller"]?.ToString();
}

<div class="app">

    <aside class="sidebar">

        <!-- Icono de 3 rayitas horizontales (Hamburguesa) -->
        <div class="menu-trigger">
            <span></span>
            <span></span>
            <span></span>
        </div>

        <div class="brand">
            GALERÍA DE ARTE
        </div>

        <div class="menu-title">
            GENERAL
        </div>

        <a asp-controller="Home"
           asp-action="Index"
           class="menu-link @(controlador == "Home" ? "active" : "")">
            Panel principal
        </a>

        <div class="menu-title">
            GESTIÓN
        </div>

        <a asp-controller="Obras"
           asp-action="Index"
           class="menu-link @(controlador == "Obras" ? "active" : "")">
            Obras
        </a>

        <a asp-controller="Artistas"
           asp-action="Index"
           class="menu-link @(controlador == "Artistas" ? "active" : "")">
            Artistas
        </a>

        <a asp-controller="Proveedores"
           asp-action="Index"
           class="menu-link @(controlador == "Proveedores" ? "active" : "")">
            Proveedores
        </a>

      
        <a asp-controller="Productos"
           asp-action="Index"
           class="menu-link @(controlador == "Productos" ? "active" : "")">
            Productos
        </a>

        <a asp-controller="Visitas"
           asp-action="Index"
           class="menu-link @(controlador == "Visitas" ? "active" : "")">
            Visitas
        </a>

        <a asp-controller="Ventas"
           asp-action="Index"
           class="menu-link @(controlador == "Ventas" ? "active" : "")">
            Ventas
        </a>

        <a asp-controller="Mantenimiento"
           asp-action="Index"
           class="menu-link @(controlador == "Mantenimiento" ? "active" : "")">
            Mantenimiento
        </a>

        <div class="logout">

            <form asp-controller="Account"
                  asp-action="Logout"
                  method="post">

                @Html.AntiForgeryToken()

                <button type="submit">
                    Cerrar sesión
                </button>

            </form>

        </div>

    </aside>

    <main class="main">

        @RenderBody()

    </main>

</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>

<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

<script src="~/js/site.js"
        asp-append-version="true"></script>

@await RenderSectionAsync(
    "Scripts",
    required: false
)

</body>

</html>















