@model GaleriaArte.Web.Models.Proveedor

@{
    ViewData["Title"] = "Editar proveedor";
}

<div class="page-header">
    <h1>Editar proveedor</h1>
    <p>Actualice la información del proveedor.</p>
</div>

<div class="form-card">

    <form asp-action="Edit" method="post">

        @Html.AntiForgeryToken()

        <input type="hidden" asp-for="IdProveedor" />

        <div asp-validation-summary="ModelOnly"
             class="validation-summary">
        </div>

        <div class="form-grid">

            <div class="form-group">
                <label asp-for="Nombre"></label>

                <input asp-for="Nombre"
                       class="form-control"
                       placeholder="Nombre del proveedor" />

                <span asp-validation-for="Nombre"
                      class="field-validation">
                </span>
            </div>

            <div class="form-group">
                <label asp-for="Telefono"></label>

                <input asp-for="Telefono"
                       class="form-control"
                       placeholder="Teléfono del proveedor" />

                <span asp-validation-for="Telefono"
                      class="field-validation">
                </span>
            </div>

            <div class="form-group">
                <label asp-for="Correo"></label>

                <input asp-for="Correo"
                       class="form-control"
                       placeholder="correo@ejemplo.com" />

                <span asp-validation-for="Correo"
                      class="field-validation">
                </span>
            </div>

            <div class="form-group">
                <label asp-for="Direccion"></label>

                <input asp-for="Direccion"
                       class="form-control"
                       placeholder="Dirección del proveedor" />

                <span asp-validation-for="Direccion"
                      class="field-validation">
                </span>
            </div>

        </div>

        <div class="form-actions">

            <a asp-action="Index"
               class="btn-secondary">
                Cancelar
            </a>

            <button type="submit"
                    class="btn-primary">
                Guardar cambios
            </button>

        </div>

    </form>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync(
            "_ValidationScriptsPartial"
        );
    }
}