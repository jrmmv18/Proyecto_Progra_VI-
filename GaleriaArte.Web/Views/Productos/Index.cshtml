@model List<GaleriaArte.Web.Models.Producto>

@{
    ViewData["Title"] = "Productos";
}

<div class="page-header page-header-actions">

    <div>
        <h1>Productos</h1>
        <p>Administración de los productos del inventario.</p>
    </div>

    <a asp-controller="Productos"
       asp-action="Create"
       class="btn-primary">
        + Nuevo producto
    </a>

</div>

@if (TempData["Mensaje"] != null)
{
    <div class="message">
        @TempData["Mensaje"]
    </div>
}

@if (Model.Count == 0)
{
    <div class="table-card">

        <div class="empty">
            No hay productos registrados.
        </div>

    </div>
}
else
{
    <div class="table-card">

        <div class="table-responsive">

            <table class="data-table">

                <thead>

                    <tr>

                        <th>Producto</th>
                        <th>Proveedor</th>
                        <th>Stock</th>
                        <th>Stock mínimo</th>
                        <th>Precio</th>
                        <th>Estado</th>
                        <th>Acciones</th>

                    </tr>

                </thead>

                <tbody>

                    @foreach (var producto in Model)
                    {
                        <tr>

                            <td>

                                <div class="obra-name">
                                    @producto.Nombre
                                </div>

                                <div class="obra-code">
                                    @producto.Codigo
                                </div>

                            </td>

                            <td>

                                <div class="artist-name">
                                    @producto.NombreProveedor
                                </div>

                            </td>

                            <td>
                                @producto.Stock
                            </td>

                            <td>
                                @producto.StockMinimo
                            </td>

                            <td>

                                ₡@producto.Precio.ToString("N2")

                            </td>

                            <td>

                                @if (producto.Estado)
                                {
                                    <span class="badge status-active">
                                        Activo
                                    </span>
                                }
                                else
                                {
                                    <span class="badge status-inactive">
                                        Inactivo
                                    </span>
                                }

                            </td>

                            <td>

                                <div class="table-actions">

                                    <a asp-controller="Productos"
                                       asp-action="Edit"
                                       asp-route-id="@producto.IdProducto"
                                       class="btn-edit">
                                        Editar
                                    </a>

                                    <form asp-controller="Productos"
                                          asp-action="CambiarEstado"
                                          asp-route-id="@producto.IdProducto"
                                          method="post">

                                        @Html.AntiForgeryToken()

                                        <button type="submit"
                                                class="btn-state">

                                            @(producto.Estado
                                                ? "Desactivar"
                                                : "Activar")

                                        </button>

                                    </form>

                                </div>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>
}